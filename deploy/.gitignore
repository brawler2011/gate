# Ignore environment files with sensitive data
.env.local
.env.dev
.env.prod
*.env

# Ignore backup files
backups/
*.dump
*.tar.gz

# Ignore SSL certificates (should be in volumes)
certbot/
*.pem
*.key
*.crt

# Ignore logs
logs/
*.log

# Ignore temporary files
*.tmp
*.swp
*.swo
*~

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore IDE files
.vscode/
.idea/
*.sublime-*

# Ignore Docker volumes (if accidentally copied locally)
postgres-data/
redis-data/
nats-data/

# Traefik ACME state
acme.json

