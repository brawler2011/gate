# Environment
ENV=local
NODE_ENV=development

# Backend listen addresses (config.go: ADDRESS, PRIVATE_ADDRESS)
ADDRESS=0.0.0.0:8080
PRIVATE_ADDRESS=0.0.0.0:8081

# Postgres Configuration (localhost — Docker ports are exposed)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=YOUR_POSTGRES_PASSWORD
POSTGRES_DB=app
POSTGRES_KRATOS_DB=kratos

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=YOUR_REDIS_PASSWORD
REDIS_DB_INDEX=0

# NATS Configuration
NATS_HOST=localhost
NATS_PORT=4222

# Kratos URLs (ports exposed from Docker)
KRATOS_URL=http://localhost:4433
KRATOS_ADMIN_URL=http://localhost:4434

# GoJudge (port exposed from Docker)
GOJUDGE_GRPC_ADDR=localhost:5051

# S3 / SeaweedFS Configuration (port exposed from Docker)
S3_ENDPOINT=http://localhost:8333
S3_ACCESS_KEY=YOUR_S3_ACCESS_KEY
S3_SECRET_KEY=YOUR_S3_SECRET_KEY

# Frontend URLs
NEXT_PUBLIC_APP_URL=http://localhost
BACKEND_API_URL=http://localhost:8080
WEBSOCKET_URL=ws://localhost:8080/ws
